VERSION 1.0 CLASS
BEGIN
  MultiUse = -1  'True
END
Attribute VB_Name = "Cls2_csv"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = False
Attribute VB_PredeclaredId = False
Attribute VB_Exposed = False
Option Explicit
Public Function IsCharCode(ByVal filePath As String, ByVal charCord As String) As Boolean
    Dim adoSt As Object
    Set adoSt = CreateObject("ADODB.Stream")
    
    With adoSt
        '// バイナリモードでファイルを開く
        '￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣
        .Type = 1 'adTypeBinary
        .Open
        .LoadFromFile filePath
        
        '// テキストモードに変更し、文字コードを自動判別する
        '￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣
        .Type = 2 'adTypeText
        .Charset = "_autodetect_all"
        
        If .Charset = charCord Then
            IsCharCode = True
        Else
            IsCharCode = False
        End If
    End With
    
    '// 後始末
    '￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣
    Set adoSt = Nothing
End Function
Public Sub CsvReading(ByVal filePath As String, ByVal charCode As String, ByRef myArray() As Variant)
    Dim i As Long
    Dim j As Long
    Dim strLine As String
    Dim arrLine As Variant
    
    '// ADODB.Streamオブジェクトを生成
    '￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣
    Dim adoSt As Object
    Set adoSt = CreateObject("ADODB.Stream")
    
    i = 0
    With adoSt
        .Charset = charCode                                                              ' Streamで扱う文字コードを設定
        .Open                                                                                   ' Streamをオープン
        .LoadFromFile (filePath)                                                          ' ファイルからStreamにデータを読み込む
        
        Do Until .EOS                                                                         ' Streamの末尾まで繰り返す
            strLine = .ReadText(adReadLine)                                         ' Streamから１行取り込み
            arrLine = Split(Replace(replacecolon(strLine), """", ""), ":")     ' strLineをカンマで区切りarrLineに格納
            
            For j = 0 To UBound(arrLine) Step 1
                myArray(i, j) = arrLine(j)
            Next j
            i = i + 1
        Loop
        .Close
    End With
    
    '// 後始末
    '￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣￣
    Set adoSt = Nothing
    Erase strLine
    Erase arrLine
End Sub
